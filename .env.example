# https://buffer.com/developers/api
BUFFER_API_KEY=your_buffer_api_key_here
# https://www.bluesky.com/docs/api/atproto/overview
# BLUESKY_HANDLE=your_bluesky_handle_here
# https://atproto.com/app-passwords — create an app password with 'Post and read posts' permissions
# BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Content curator — how many entries to scan per RSS feed before filtering
# Higher = more variety; lower = faster. Default: 7
# CURATOR_MAX_PER_FEED=7

# RSS feeds to scan (JSON array — overrides built-in defaults entirely)
# CURATOR_RSS_FEEDS=[{"name":"Anthropic Blog","url":"https://www.anthropic.com/rss.xml"},{"name":"My Blog","url":"https://myblog.com/feed.xml"}]

# Niche keywords for filtering articles (comma-separated — overrides built-in defaults)
# CURATOR_KEYWORDS=RAG,retrieval augmented,LLM,language model,neo4j,graph,elasticsearch,vector search,agent,multi-agent,MCP,model context protocol,government AI,GovTech,regulatory,compliance AI,Java AI,Spring AI,FastAPI,Spring Boot,Spring Batch,Java 21,virtual thread,reinforcement learning,scikit-learn,embeddings,BM25,Solr,Lucene,NLP,sentence transformer,context engineering,event-driven,event broker,Solace,PubSub,streaming,microservices,Docker,Groq,OpenRouter,Perplexity AI,Ollama,Vaadin,FastMCP,kNN,feature engineering,neural network,agentic,agentic AI,Supabase,vector database,knowledge graph

# ---------------------------------------------------------------------------
# SSI post focus — how often each pillar gets a post (should add up to 100).
# Bump a pillar up when it's lagging; dial it back when it improves.
# ---------------------------------------------------------------------------
# SSI_FOCUS_ESTABLISH_BRAND=25
# SSI_FOCUS_FIND_RIGHT_PEOPLE=27
# SSI_FOCUS_ENGAGE_WITH_INSIGHTS=24
# SSI_FOCUS_BUILD_RELATIONSHIPS=24

# ---------------------------------------------------------------------------
# Scheduler settings (optional)
# Controls how --generate --schedule selects publish weekdays/times.
#
# Timezone used for local slot calculation before conversion to UTC for Buffer.
# Use IANA timezone names (e.g. America/Toronto, America/New_York, Europe/London).
# SCHEDULER_TIMEZONE=America/Toronto
#
# Posting slots used each scheduled week.
# Format: day@HH:MM,day@HH:MM
# - day: monday..sunday
# - time: 24-hour HH:MM
# - order matters (slot 1 gets the first selected post, slot 2 gets the second, etc.)
# - number of slots = max posts scheduled per week per channel
#
# Example (default behavior):
# SCHEDULER_POSTING_SLOTS=tuesday@16:00,wednesday@16:00,friday@16:00
#
# Example (4-post cadence):
# SCHEDULER_POSTING_SLOTS=monday@09:30,tuesday@16:00,thursday@11:00,friday@16:00

# Local Ollama — requires Ollama running at OLLAMA_BASE_URL

# Ollama model selection:
#   - gemma4:26b    (best quality, recommended — MoE, 3.8B active params, native system role, thinking mode)
#   - qwen2.5:14b   (strong instruction-following, good fallback if VRAM is limited ~9GB)
#   - mistral-nemo  (12b, fast & strong middle ground)
#   - llama3.2      (3b, fastest, lower quality)
#   - phi3:mini     (3.8b, very fast, concise)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:26b

# ---------------------------------------------------------------------------
# GitHub repo context (optional)
# When set, public repo metadata is fetched, formatted, and appended to
# PROFILE_CONTEXT so the LLM knows your real projects.
# Results are cached for 24 hours in github_repos_cache.json.
# ---------------------------------------------------------------------------

# GITHUB_USER=your_github_username

# Optional — raises unauthenticated rate limit from 60 to 5000 req/hr
# GITHUB_TOKEN=ghp_your_personal_access_token

# Comma-separated list of repo names to include.
# If omitted, all non-fork public repos are included.
# GITHUB_REPO_FILTER=repo-name-1,repo-name-2,repo-name-3

# Include compact README summaries in GitHub context block (default: true)
# GITHUB_INCLUDE_README_SUMMARIES=true

# Max number of repos to include in prompt context (default: 12)
# GITHUB_REPO_MAX_COUNT=12

# Max chars per README summary snippet (default: 1200)
# GITHUB_README_MAX_CHARS=1200

# Max chars allocated to GitHub-derived context (default: 30000)
# GITHUB_CONTEXT_MAX_CHARS=30000

# Max total chars for PROFILE_CONTEXT + GitHub block after assembly (default: 120000)
# PROFILE_CONTEXT_MAX_CHARS=120000

# Truth grounding tech keywords (comma-separated)
#
# What this controls:
# - The grounding layer scans user prompts/topics/articles for these terms.
# - It also scans PROFILE_CONTEXT project bullets for these terms to build fact tags.
# - Matching terms increase retrieval score for relevant facts.
#
# Where this is used:
# - --console: deterministic factual answers (project/company/year/details).
# - --generate: selects allowed personal facts for topic-based post writing.
# - --curate: selects allowed personal facts for article-based commentary.
#
# Practical effect:
# - Better matches -> stronger, more relevant grounded facts.
# - Missing keywords -> fewer relevant facts retrieved -> model may avoid personal claims.
#
# Tuning tips:
# - Use lowercase terms.
# - Include both broad and specific terms (e.g. java, spring, spring ai, rag).
# - Include abbreviations your profile uses (e.g. jms, mcp, knn).
# - Keep the list focused; noisy terms reduce ranking quality.
#
# If unset, built-in defaults are used.
# CONSOLE_GROUNDING_TECH_KEYWORDS=java,spring,jms,python,fastapi,elasticsearch,solr,lucene,neo4j,rag,mcp,oracle,weblogic,vaadin

# Truth grounding tag expansions (optional)
#
# What this controls:
# - Expands a detected base keyword into related keywords before fact retrieval.
# - Helps broad queries pull in the right adjacent stack facts.
#
# Example behavior:
# - Query contains "java" -> retrieval also considers spring, jms, oracle, weblogic, etc.
# - Query contains "python" -> retrieval also considers fastapi, scikit-learn, etc.
#
# Why this matters:
# - Real prompts often use umbrella terms (java/python) instead of exact stack terms.
# - Expansions improve recall without forcing users to type every specific technology.
#
# Format:
# - base:related1|related2;otherbase:relatedA|relatedB
# - ';' separates base groups, ':' separates base from related set, '|' separates related terms
# - Keep all values lowercase.
#
# If unset, built-in defaults are used.
# CONSOLE_GROUNDING_TAG_EXPANSIONS=java:spring|jms|oracle|weblogic|solr|lucene|elasticsearch;python:fastapi|scikit-learn

# ---------------------------------------------------------------------------
# Your profile context — injected into every AI prompt so posts sound like you.
# Required. Keep this in .env (gitignored) — it contains personal career details.
# Multi-line values must stay within the surrounding double-quotes.
# ---------------------------------------------------------------------------
# PROFILE_CONTEXT="Name: Your Full Name
# Title: Your Job Title
# Location: Your City/Remote
# Links: github.com/your-username | your-website.com | linkedin.com/in/your-profile
#
# Core expertise: list your main technical areas
# Languages & frameworks: list your primary stack
#
# Key projects (use these for specifics — never fabricate numbers):
# - Project Name (year): What you built, key metrics, tech stack
# - Project Name (year): What you built, key metrics, tech stack
#
# Experience: X years in Y; current focus Z
# Goal: What you want to be known for on LinkedIn
# Tone: How you want to sound (e.g. technical but human, concise, direct)"

# ---------------------------------------------------------------------------
# AI Persona & SSI Instructions (optional — uncomment and edit to customise)
# All values below show the built-in defaults. Override without touching code.
# Multi-line values must stay within the surrounding double-quotes.
# ---------------------------------------------------------------------------

# PERSONA_SYSTEM_PROMPT="You are a LinkedIn ghostwriter for [Your Full Name] — [Your Title], [Your Location].
# [Name] has [X]+ years of [primary language/platform] experience and since [year] has focused on [your current specialty: e.g. AI engineering, RAG pipelines, cloud-native systems].
# Recent projects — draw on these for posts:
# - [Project Name] ([year]): [What you built, key metrics, tech stack]
# - [Project Name] ([year]): [What you built, key metrics, tech stack]
# Legacy experience — draw on these ONLY for posts about [legacy tech/domain]. NEVER connect this work to [unrelated area]:
# - [Employer] ([years]): [What you did, scale, tech]
# CRITICAL: [Any hard boundary — e.g. 'The legacy work had nothing to do with LLMs. Never imply it did.']
# Target audience: [Who you want to reach — e.g. AI engineers, Java architects, startup CTOs]
# Voice: [How you want to sound — e.g. technical but human, concise, direct, occasionally contrarian]
# Forbidden phrases: 'In the age of AI', 'Game changer', 'Exciting to share', 'Thrilled to announce', 'Delighted to', 'I am pleased to', 'landscape', 'leverage', 'unlock', 'revolutionize'.
# Format rules: Never start with 'I'. No bullet points in the post body — write in short punchy paragraphs. No hollow openers or conclusions. No corporate jargon or passive voice.
# Technical glossary — these definitions are exact and authoritative. Never redefine, expand, or paraphrase them differently:
# RAG = Retrieval-Augmented Generation (a technique that grounds LLM responses with retrieved documents)
# BM25 = Best Match 25 (probabilistic term-frequency ranking algorithm used in Elasticsearch/Lucene)
# kNN = k-Nearest Neighbors (vector similarity search)
# NLP = Natural Language Processing
# MCP = Model Context Protocol (Anthropic open standard for tool-calling agents)
# [TERM] = [Definition] — add any domain-specific abbreviations your audience uses
# Hard rule: Never spell out or expand a technical abbreviation unless it appears in the glossary above. If an abbreviation is not in the glossary, leave it as-is rather than guessing.
# IMPORTANT: Output plain text only — no Markdown. Do not use **, ##, __, `, or any other Markdown syntax. LinkedIn does not render Markdown."

# ------------------------------------------------------------------------------
# The "NLP —" sections below refer to Neuro-Linguistic Programming — a framework
# for influence and communication. Each pillar uses a specific NLP technique to
# make posts more persuasive and psychologically resonant with the target reader:
#   - Authority anchoring    (Establish Brand)
#   - Identity pacing        (Find Right People)
#   - Pattern interrupt      (Engage with Insights)
#   - Sensory storytelling   (Build Relationships)
# These are baked into the prompt so the AI applies them automatically.
#
# "There's no such thing as hypnosis... and this is it."
#   — Steven Heller, Monsters and Magical Sticks 
# (notes: https://richardstep.com/downloads/tools/Notes--Monsters-and-Magic-Sticks.pdf)
# ------------------------------------------------------------------------------

# SSI_ESTABLISH_BRAND="This post should ESTABLISH PROFESSIONAL BRAND.
# Your brand pillars — draw on these specifically when relevant:
# - [Pillar 1]: [specific project or achievement with a real number or outcome]
# - [Pillar 2]: [specific project or achievement with a real number or outcome]
# - [Pillar 3]: [specific skill or tool area with depth — e.g. 'X years with Elasticsearch']
# Writing rules:
# - Reference a real project, a specific number, a concrete architectural decision, or a hard lesson
# - Show depth — not 'I used RAG' but what index design you chose and why it mattered
# - End with a clear POV: what you'd do differently, what surprised you, what you stand behind
# - Write something practitioners will screenshot and save
# NLP — Authority anchoring:
# - Use certainty language and present-tense declarations ('The bottleneck is always X', 'This is what breaks at scale') — never hedge with 'I think' or 'maybe'
# - Presuppose the reader already understands the domain; write at their level, then pull them one step further
# - Embed the reader into the scenario: 'When you're designing at this scale, you discover...' — makes the expertise feel transferable, not boastful
# - Anchor credibility to specific outcomes and decisions, not titles or years of experience"

# SSI_FIND_RIGHT_PEOPLE="This post should help FIND THE RIGHT PEOPLE.
# - Mention specific tools, communities, or events relevant to your niche
# - Ask a question that invites replies from your target audience
# - Tag relevant communities or technologies (not people)
# - This drives profile visits from the right professionals
# NLP — Identity pacing and selective inclusion:
# - Open by mirroring the worldview of your exact target reader (pacing) — write an opener that assumes the reader already works in this space and already understands the problem. The opener must be specific to what THIS post is actually about. Example pattern: 'If you're building [topic of this post] at scale, you already know that [specific challenge in that domain]...' — the bracket content must match the article topic.
# - Use identity-based framing: 'The engineers who care about this are the ones who...' — causes the right audience to self-select in and the wrong audience to scroll past
# - Lead from their current reality to a new perspective they didn't have before (pacing → leading)
# - The closing question should be so specific to your niche that only the right engineers would have a meaningful answer to it"

# SSI_ENGAGE_WITH_INSIGHTS="This post should ENGAGE WITH INSIGHTS.
# - Reference or summarize a recent AI paper, article, or trend
# - Give YOUR take on it — don't just summarize
# - Make a bold or counterintuitive claim based on your experience
# - Invite discussion: 'What's your experience with this?'
# - This component rewards thoughtful engagement on others' content too
# NLP — Pattern interrupt and cognitive reframe:
# - Open with a pattern interrupt: a claim that directly contradicts the conventional wisdom on this topic — force the reader to stop scrolling
# - Use contrast structure to anchor the reframe: 'Everyone ships X. The teams that actually scale do Y.' — the contrast creates the insight
# - Reframe the finding in terms of what it means practically for someone building real systems, not what it means theoretically
# - End with a specific question that implies the reader has relevant experience — not 'what do you think?' but 'have you hit this wall when doing X?' — creates productive dissonance that demands a reply"

# SSI_BUILD_RELATIONSHIPS="This post should BUILD RELATIONSHIPS.
# - Share a behind-the-scenes story or honest lesson from a project
# - Be specific about challenges you faced and how you solved them
# - Show personality — not just technical facts
# - Make it feel like a conversation, not a press release
# - End with something that invites comments and connection
# NLP — Rapport through sensory storytelling and vulnerability:
# - Drop the reader into the middle of the moment — skip all preamble and open with a specific scene: 'It was the third deploy attempt. The index was corrupt.' — sensory detail creates presence
# - Use 'we' where natural; it signals collaboration and humanity rather than lone-genius posturing
# - Include a moment of genuine uncertainty, failure, or surprise before the resolution — vulnerability is what creates trust, not polish
# - The closing question should invite the reader to share their own parallel experience, not just react to yours — 'Has your team hit this?' beats 'Thoughts?'"

# ---------------------------------------------------------------------------
# YouTube Short spoken script persona (lipsync.video avatar)
# Used when --channel youtube is selected
# ---------------------------------------------------------------------------
# YOUTUBE_SHORT_SYSTEM_PROMPT="IMPORTANT — this is a YouTube Short spoken script for [Your Avatar Name]:
# - [Avatar name] is your digital avatar. Write entirely in the avatar's voice, first-person.
# - Begin with this exact intro: [Your avatar's opening line]
# - Target: 100-150 words maximum (60-second Short) — do NOT exceed 150 words
# - Spoken word only — natural contractions, conversational cadence, no jargon walls
# - No hashtags, no markdown, no bullet points, no stage directions
# - Structure: hook (1-2 sentences) → insight or story (3-4 sentences) → subscribe CTA
# - Close with exactly: [Your subscribe CTA]
# - Every sentence must be speakable aloud naturally"
